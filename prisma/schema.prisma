generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CallSession {
  id             String        @id @default(uuid())
  startTime      DateTime      @default(now())
  endTime        DateTime?
  callerId       String
  callerName     String?
  recipientId    String
  status         String        @default("ongoing")
  direction      String        @default("outbound")
  duration       Int?
  ipAddress      String?
  geoCity        String?
  geoCountry     String?
  geoLat         Float?
  geoLon         Float?
  audioUrl       String?
  notes          String?
  injectedData   InjectedData?
  dossier        Dossier?
}

model InjectedData {
  id              String       @id @default(uuid())
  callSessionId   String       @unique
  callSession     CallSession  @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  gpsCoordinates  String?
  facialMatch     String?
  cameraHits      String?
  satelliteIntel  String?
  extraPayload    String?
  receivedAt      DateTime     @default(now())
}

model Dossier {
  id            String       @id @default(uuid())
  callSessionId String       @unique
  callSession   CallSession  @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  compiledAt    DateTime     @default(now())
  status        String       @default("pending")
  adminEmail    String       @default("admin@shopyle.com")
  content       String
}

model Agent {
  id          String   @id @default(uuid())
  name        String
  extension   String   @unique
  status      String   @default("offline")
  createdAt   DateTime @default(now())
}
